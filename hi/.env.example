# Supabase → Project Settings → API
# URL: copy "Project URL" exactly (must look like https://xxxxxxxx.supabase.co — not YOUR_PROJECT_REF)
# Key: "anon" / "publishable" public key — never the service_role secret
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key_here

# Google AI (Gemini) for Genkit chat + project recommender — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: canonical URL + OG tags (e.g. https://yoursite.com)
NEXT_PUBLIC_SITE_URL=

# Optional: Plausible Analytics domain (no script loads if unset)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
